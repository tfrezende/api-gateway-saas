{
  "title": "API Gateway",
  "uid": "api-gateway",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Request rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_requests_total[1m])) by (method, path)",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_errors_total[1m])) by (method, path, status_code)",
          "legendFormat": "{{method}} {{path}} {{status_code}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p99 latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(api_gateway_request_latency_seconds_bucket[1m])) by (le, method, path))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "p50 latency (seconds)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(api_gateway_request_latency_seconds_bucket[1m])) by (le, method, path))",
          "legendFormat": "{{method}} {{path}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Rate limited requests",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(api_gateway_errors_total{status_code=\"429\"}[1m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total requests",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(api_gateway_requests_total)",
          "legendFormat": "Total"
        }
      ]
    }
  ]
}